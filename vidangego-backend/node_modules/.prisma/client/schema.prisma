// This is your Prisma schema file for local development,
// learn more about it in docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
  MECHANIC
}

enum ServiceType {
  STANDARD
  OIL_CHANGE
  REPAIR
}

enum MissionStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clientVehicles   Vehicle[]  @relation("ClientVehicles")
  missions         Mission[]  @relation("ClientMissions")
  assignedMissions Mission[]  @relation("MechanicMissions")
  locations        Location[]

  @@map("users")
}

model Vehicle {
  id           String   @id @default(cuid())
  brand        String
  model        String
  year         Int
  licensePlate String   @unique
  oilType      String?
  clientId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  client   User      @relation("ClientVehicles", fields: [clientId], references: [id], onDelete: Cascade)
  missions Mission[]

  @@map("vehicles")
}

model Mission {
  id          String        @id @default(cuid())
  clientId    String
  vehicleId   String
  mechanicId  String?
  serviceType ServiceType   @default(OIL_CHANGE)
  status      MissionStatus @default(PENDING)
  address     String
  lat         Float?
  lng         Float?
  notes       String?
  totalPrice  Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  client    User       @relation("ClientMissions", fields: [clientId], references: [id], onDelete: Cascade)
  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mechanic  User?      @relation("MechanicMissions", fields: [mechanicId], references: [id], onDelete: SetNull)
  locations Location[]

  @@map("missions")
}

model Location {
  id        String   @id @default(cuid())
  missionId String
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
  userId    String?

  // Relations
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("locations")
}

model Inventory {
  id          String   @id @default(cuid())
  name        String
  description String?
  quantity    Int      @default(0)
  price       Float
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inventory")
}
